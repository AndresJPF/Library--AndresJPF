---
import UserComponent from '../components/UserComponent.astro';
import AuthorComponent from '../components/AuthorComponent.astro';
import BookComponent from '../components/BookComponent.astro';
import LoanComponent from '../components/LoanComponent.astro';

const BASE = "http://localhost:8080/Library-Backend";

const [usersRes, authorsRes, booksRes, loansRes] = await Promise.all([
  fetch(`${BASE}/users`),
  fetch(`${BASE}/authors`),
  fetch(`${BASE}/books`),
  fetch(`${BASE}/loans`),
]);

const users   = await usersRes.json();
const authors = await authorsRes.json();
const books   = await booksRes.json();
const loans   = await loansRes.json();
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Library Admin</title>
  <style>
    /* ── Variables ── */
    :root {
      --bg:        #0f1117;
      --surface:   #1a1d27;
      --border:    #2a2d3a;
      --accent:    #4f8ef7;
      --accent2:   #e05c5c;
      --text:      #e8eaf0;
      --text-muted:#7a7f9a;
      --radius:    8px;
      --font:      'Segoe UI', system-ui, sans-serif;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: var(--font);
      min-height: 100vh;
      padding: 2rem;
    }

    h1 {
      font-size: 2rem;
      font-weight: 700;
      letter-spacing: -0.5px;
      margin-bottom: 0.25rem;
    }

    .subtitle {
      color: var(--text-muted);
      margin-bottom: 2.5rem;
      font-size: 0.95rem;
    }

    /* ── Tabs ── */
    .tabs {
      display: flex;
      gap: 0.5rem;
      margin-bottom: 1.5rem;
      border-bottom: 1px solid var(--border);
      padding-bottom: 0.5rem;
    }

    .tab-btn {
      background: none;
      border: none;
      color: var(--text-muted);
      font-size: 0.95rem;
      padding: 0.5rem 1.2rem;
      border-radius: var(--radius) var(--radius) 0 0;
      cursor: pointer;
      transition: all 0.2s;
    }

    .tab-btn:hover { color: var(--text); }

    .tab-btn.active {
      background: var(--surface);
      color: var(--accent);
      border: 1px solid var(--border);
      border-bottom: 1px solid var(--surface);
      margin-bottom: -1px;
    }

    /* ── Sections ── */
    .section { display: none; }
    .section.active { display: block; }

    /* ── Cards ── */
    .card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 1.5rem;
      margin-bottom: 1.5rem;
    }

    .card h2 {
      font-size: 1rem;
      font-weight: 600;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 1px;
      margin-bottom: 1rem;
    }

    /* ── Forms ── */
    .form-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
      gap: 0.75rem;
      align-items: end;
    }

    .form-group { display: flex; flex-direction: column; gap: 0.35rem; }

    label {
      font-size: 0.8rem;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    input {
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      color: var(--text);
      padding: 0.55rem 0.75rem;
      font-size: 0.9rem;
      transition: border-color 0.2s;
      outline: none;
    }

    input:focus { border-color: var(--accent); }

    /* ── Buttons ── */
    .btn {
      padding: 0.55rem 1.2rem;
      border: none;
      border-radius: var(--radius);
      font-size: 0.9rem;
      font-weight: 600;
      cursor: pointer;
      transition: opacity 0.2s, transform 0.1s;
    }

    .btn:hover { opacity: 0.85; }
    .btn:active { transform: scale(0.97); }

    .btn-primary  { background: var(--accent);  color: #fff; }
    .btn-warning  { background: #d4840a;        color: #fff; }
    .btn-cancel   { background: var(--border);  color: var(--text); }

    /* Component buttons (inline table) */
    .btn-edit   { background: #2a4a8a; color: #7eb3ff; border: none; border-radius: 5px; padding: 0.3rem 0.7rem; font-size: 0.8rem; cursor: pointer; }
    .btn-delete { background: #4a1f1f; color: #ff7e7e; border: none; border-radius: 5px; padding: 0.3rem 0.7rem; font-size: 0.8rem; cursor: pointer; margin-left: 0.4rem; }

    /* ── Modal overlay ── */
    .modal-overlay {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.6);
      z-index: 100;
      align-items: center;
      justify-content: center;
    }

    .modal-overlay.open { display: flex; }

    .modal {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 2rem;
      width: 100%;
      max-width: 480px;
    }

    .modal h2 {
      margin-bottom: 1.25rem;
      font-size: 1.1rem;
    }

    .modal-actions {
      display: flex;
      gap: 0.75rem;
      justify-content: flex-end;
      margin-top: 1.25rem;
    }

    /* ── Table ── */
    .table-wrap { overflow-x: auto; }

    table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.9rem;
    }

    th {
      text-align: left;
      padding: 0.6rem 0.75rem;
      color: var(--text-muted);
      font-size: 0.78rem;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      border-bottom: 1px solid var(--border);
    }

    .table-row td {
      padding: 0.65rem 0.75rem;
      border-bottom: 1px solid var(--border);
      vertical-align: middle;
    }

    .table-row:last-child td { border-bottom: none; }
    .table-row:hover { background: rgba(255,255,255,0.03); }

    /* ── Toast ── */
    #toast {
      position: fixed;
      bottom: 1.5rem;
      right: 1.5rem;
      background: var(--surface);
      border: 1px solid var(--border);
      border-left: 3px solid var(--accent);
      border-radius: var(--radius);
      padding: 0.75rem 1.25rem;
      font-size: 0.9rem;
      opacity: 0;
      transform: translateY(10px);
      transition: all 0.3s;
      pointer-events: none;
      z-index: 200;
    }

    #toast.show {
      opacity: 1;
      transform: translateY(0);
    }
  </style>
</head>
<body>

  <h1>📚 Library Admin</h1>
  <p class="subtitle">Panel de administración de la biblioteca</p>

  <!-- ── Tabs ── -->
  <div class="tabs">
    <button class="tab-btn active" onclick="showTab('users')">Usuarios</button>
    <button class="tab-btn"       onclick="showTab('authors')">Autores</button>
    <button class="tab-btn"       onclick="showTab('books')">Libros</button>
    <button class="tab-btn"       onclick="showTab('loans')">Préstamos</button>
  </div>

  <!-- ══════════════════════════════════════════
       USUARIOS
  ══════════════════════════════════════════ -->
  <div id="tab-users" class="section active">

    <div class="card">
      <h2>➕ Nuevo Usuario</h2>
      <div class="form-grid">
        <div class="form-group">
          <label>Nombre</label>
          <input id="u-name" type="text" placeholder="Juan" />
        </div>
        <div class="form-group">
          <label>Apellido</label>
          <input id="u-lastname" type="text" placeholder="Pérez" />
        </div>
        <div class="form-group">
          <label>Email</label>
          <input id="u-email" type="email" placeholder="juan@mail.com" />
        </div>
        <div class="form-group">
          <label>Teléfono</label>
          <input id="u-phone" type="text" placeholder="3001234567" />
        </div>
        <div class="form-group">
          <label>&nbsp;</label>
          <button class="btn btn-primary" onclick="createUser()">Crear</button>
        </div>
      </div>
    </div>

    <div class="card">
      <h2>📋 Lista de Usuarios</h2>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>ID</th><th>Nombre</th><th>Apellido</th>
              <th>Email</th><th>Teléfono</th><th>Acciones</th>
            </tr>
          </thead>
          <tbody id="userList">
            {users.map((user: any) => <UserComponent user={user} />)}
          </tbody>
        </table>
      </div>
    </div>

  </div>

  <!-- ══════════════════════════════════════════
       AUTORES
  ══════════════════════════════════════════ -->
  <div id="tab-authors" class="section">

    <div class="card">
      <h2>➕ Nuevo Autor</h2>
      <div class="form-grid">
        <div class="form-group">
          <label>Nombre</label>
          <input id="a-name" type="text" placeholder="Gabriel" />
        </div>
        <div class="form-group">
          <label>Apellido</label>
          <input id="a-lastname" type="text" placeholder="García Márquez" />
        </div>
        <div class="form-group">
          <label>Nacionalidad</label>
          <input id="a-nationality" type="text" placeholder="Colombiano" />
        </div>
        <div class="form-group">
          <label>&nbsp;</label>
          <button class="btn btn-primary" onclick="createAuthor()">Crear</button>
        </div>
      </div>
    </div>

    <div class="card">
      <h2>📋 Lista de Autores</h2>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>ID</th><th>Nombre</th><th>Apellido</th>
              <th>Nacionalidad</th><th>Acciones</th>
            </tr>
          </thead>
          <tbody id="authorList">
            {authors.map((author: any) => <AuthorComponent author={author} />)}
          </tbody>
        </table>
      </div>
    </div>

  </div>

  <!-- ══════════════════════════════════════════
       LIBROS
  ══════════════════════════════════════════ -->
  <div id="tab-books" class="section">

    <div class="card">
      <h2>➕ Nuevo Libro</h2>
      <div class="form-grid">
        <div class="form-group">
          <label>Título</label>
          <input id="b-title" type="text" placeholder="Cien años de soledad" />
        </div>
        <div class="form-group">
          <label>ISBN</label>
          <input id="b-isbn" type="text" placeholder="978-3-16-148410-0" />
        </div>
        <div class="form-group">
          <label>Año</label>
          <input id="b-year" type="text" placeholder="1967" />
        </div>
        <div class="form-group">
          <label>ID Autor</label>
          <input id="b-author" type="number" placeholder="1" />
        </div>
        <div class="form-group">
          <label>&nbsp;</label>
          <button class="btn btn-primary" onclick="createBook()">Crear</button>
        </div>
      </div>
    </div>

    <div class="card">
      <h2>📋 Lista de Libros</h2>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>ID</th><th>Título</th><th>ISBN</th>
              <th>Año</th><th>ID Autor</th><th>Acciones</th>
            </tr>
          </thead>
          <tbody id="bookList">
            {books.map((book: any) => <BookComponent book={book} />)}
          </tbody>
        </table>
      </div>
    </div>

  </div>

  <!-- ══════════════════════════════════════════
       PRÉSTAMOS
  ══════════════════════════════════════════ -->
  <div id="tab-loans" class="section">

    <div class="card">
      <h2>➕ Nuevo Préstamo</h2>
      <div class="form-grid">
        <div class="form-group">
          <label>ID Usuario</label>
          <input id="l-user" type="number" placeholder="1" />
        </div>
        <div class="form-group">
          <label>ID Libro</label>
          <input id="l-book" type="number" placeholder="1" />
        </div>
        <div class="form-group">
          <label>&nbsp;</label>
          <button class="btn btn-primary" onclick="createLoan()">Crear</button>
        </div>
      </div>
    </div>

    <div class="card">
      <h2>📋 Lista de Préstamos</h2>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>ID</th><th>Fecha Préstamo</th><th>Fecha Devolución</th>
              <th>ID Usuario</th><th>ID Libro</th><th>Acciones</th>
            </tr>
          </thead>
          <tbody id="loanList">
            {loans.map((loan: any) => <LoanComponent loan={loan} />)}
          </tbody>
        </table>
      </div>
    </div>

  </div>

  <!-- ══════════════════════════════════════════
       MODALES DE EDICIÓN
  ══════════════════════════════════════════ -->

  <!-- Modal editar usuario -->
  <div id="modal-user" class="modal-overlay">
    <div class="modal">
      <h2>✏️ Editar Usuario</h2>
      <div class="form-grid" style="grid-template-columns: 1fr 1fr;">
        <input type="hidden" id="eu-id" />
        <div class="form-group">
          <label>Nombre</label>
          <input id="eu-name" type="text" />
        </div>
        <div class="form-group">
          <label>Apellido</label>
          <input id="eu-lastname" type="text" />
        </div>
        <div class="form-group">
          <label>Email</label>
          <input id="eu-email" type="email" />
        </div>
        <div class="form-group">
          <label>Teléfono</label>
          <input id="eu-phone" type="text" />
        </div>
      </div>
      <div class="modal-actions">
        <button class="btn btn-cancel"  onclick="closeModal('modal-user')">Cancelar</button>
        <button class="btn btn-warning" onclick="updateUser()">Guardar</button>
      </div>
    </div>
  </div>

  <!-- Modal editar autor -->
  <div id="modal-author" class="modal-overlay">
    <div class="modal">
      <h2>✏️ Editar Autor</h2>
      <div class="form-grid" style="grid-template-columns: 1fr 1fr;">
        <input type="hidden" id="ea-id" />
        <div class="form-group">
          <label>Nombre</label>
          <input id="ea-name" type="text" />
        </div>
        <div class="form-group">
          <label>Apellido</label>
          <input id="ea-lastname" type="text" />
        </div>
        <div class="form-group" style="grid-column: 1 / -1;">
          <label>Nacionalidad</label>
          <input id="ea-nationality" type="text" />
        </div>
      </div>
      <div class="modal-actions">
        <button class="btn btn-cancel"  onclick="closeModal('modal-author')">Cancelar</button>
        <button class="btn btn-warning" onclick="updateAuthor()">Guardar</button>
      </div>
    </div>
  </div>

  <!-- Modal editar libro -->
  <div id="modal-book" class="modal-overlay">
    <div class="modal">
      <h2>✏️ Editar Libro</h2>
      <div class="form-grid" style="grid-template-columns: 1fr 1fr;">
        <input type="hidden" id="eb-id" />
        <div class="form-group" style="grid-column: 1 / -1;">
          <label>Título</label>
          <input id="eb-title" type="text" />
        </div>
        <div class="form-group">
          <label>ISBN</label>
          <input id="eb-isbn" type="text" />
        </div>
        <div class="form-group">
          <label>Año</label>
          <input id="eb-year" type="text" />
        </div>
        <div class="form-group">
          <label>ID Autor</label>
          <input id="eb-author" type="number" />
        </div>
      </div>
      <div class="modal-actions">
        <button class="btn btn-cancel"  onclick="closeModal('modal-book')">Cancelar</button>
        <button class="btn btn-warning" onclick="updateBook()">Guardar</button>
      </div>
    </div>
  </div>

  <!-- Toast -->
  <div id="toast"></div>

  <!-- ══════════════════════════════════════════
       SCRIPTS
  ══════════════════════════════════════════ -->
  <script>
    const BASE = "http://localhost:8080/Library-Backend";

    // ── Utilidades ──────────────────────────────────────────────────
    function val(id: string): string {
      return (document.getElementById(id) as HTMLInputElement).value.trim();
    }

    function setVal(id: string, v: string) {
      (document.getElementById(id) as HTMLInputElement).value = v;
    }

    function toast(msg: string, ok = true) {
      const el = document.getElementById("toast")!;
      el.textContent = msg;
      el.style.borderLeftColor = ok ? "var(--accent)" : "var(--accent2)";
      el.classList.add("show");
      setTimeout(() => el.classList.remove("show"), 2500);
    }

    function closeModal(id: string) {
      document.getElementById(id)!.classList.remove("open");
    }

    // ── Tabs ────────────────────────────────────────────────────────
    (window as any).showTab = (name: string) => {
      document.querySelectorAll(".section").forEach(s => s.classList.remove("active"));
      document.querySelectorAll(".tab-btn").forEach(b => b.classList.remove("active"));
      document.getElementById(`tab-${name}`)!.classList.add("active");
      document.querySelectorAll(".tab-btn").forEach(b => {
        if ((b as HTMLElement).textContent?.toLowerCase().includes(name === 'loans' ? 'prést' : name.slice(0,4))) {
          b.classList.add("active");
        }
      });
    };

    // ════════════════════════════════
    //  USERS
    // ════════════════════════════════

    (window as any).createUser = async () => {
      const params = new URLSearchParams({
        name: val("u-name"), lastname: val("u-lastname"),
        email: val("u-email"), phone: val("u-phone"),
      });
      const res = await fetch(`${BASE}/users`, { method: "POST", body: params });
      if (res.ok) { toast("Usuario creado ✅"); location.reload(); }
      else toast("Error al crear usuario ❌", false);
    };

    (window as any).openEditUser = (id: number, name: string, lastName: string, email: string, phone: string) => {
      setVal("eu-id", String(id));
      setVal("eu-name", name);
      setVal("eu-lastname", lastName);
      setVal("eu-email", email);
      setVal("eu-phone", phone);
      document.getElementById("modal-user")!.classList.add("open");
    };

    (window as any).updateUser = async () => {
      const body = {
        idUser: parseInt(val("eu-id")),
        name: val("eu-name"),
        lastName: val("eu-lastname"),
        email: val("eu-email"),
        phone: val("eu-phone"),
      };
      const res = await fetch(`${BASE}/users`, {
        method: "PUT",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(body),
      });
      if (res.ok) { toast("Usuario actualizado ✅"); closeModal("modal-user"); location.reload(); }
      else toast("Error al actualizar ❌", false);
    };

    (window as any).deleteUser = async (id: number) => {
      if (!confirm(`¿Eliminar usuario ${id}?`)) return;
      const res = await fetch(`${BASE}/users?id=${id}`, { method: "DELETE" });
      if (res.ok) { document.getElementById(`user-${id}`)?.remove(); toast("Usuario eliminado 🗑️"); }
      else toast("Error al eliminar ❌", false);
    };

    // ════════════════════════════════
    //  AUTHORS
    // ════════════════════════════════

    (window as any).createAuthor = async () => {
      const params = new URLSearchParams({
        name: val("a-name"), lastname: val("a-lastname"),
        nationality: val("a-nationality"),
      });
      const res = await fetch(`${BASE}/authors`, { method: "POST", body: params });
      if (res.ok) { toast("Autor creado ✅"); location.reload(); }
      else toast("Error al crear autor ❌", false);
    };

    (window as any).openEditAuthor = (id: number, name: string, lastname: string, nationality: string) => {
      setVal("ea-id", String(id));
      setVal("ea-name", name);
      setVal("ea-lastname", lastname);
      setVal("ea-nationality", nationality);
      document.getElementById("modal-author")!.classList.add("open");
    };

    (window as any).updateAuthor = async () => {
      const id = val("ea-id");
      const params = `id=${id}&name=${val("ea-name")}&lastname=${val("ea-lastname")}&nationality=${val("ea-nationality")}`;
      const res = await fetch(`${BASE}/authors?${params}`, { method: "PUT" });
      if (res.ok) { toast("Autor actualizado ✅"); closeModal("modal-author"); location.reload(); }
      else toast("Error al actualizar ❌", false);
    };

    (window as any).deleteAuthor = async (id: number) => {
      if (!confirm(`¿Eliminar autor ${id}?`)) return;
      const res = await fetch(`${BASE}/authors?id=${id}`, { method: "DELETE" });
      if (res.ok) { document.getElementById(`author-${id}`)?.remove(); toast("Autor eliminado 🗑️"); }
      else toast("Error al eliminar ❌", false);
    };

    // ════════════════════════════════
    //  BOOKS
    // ════════════════════════════════

    (window as any).createBook = async () => {
      const params = new URLSearchParams({
        title: val("b-title"), isbn: val("b-isbn"),
        year: val("b-year"),   id_author: val("b-author"),
      });
      const res = await fetch(`${BASE}/books`, { method: "POST", body: params });
      if (res.ok) { toast("Libro creado ✅"); location.reload(); }
      else toast("Error al crear libro ❌", false);
    };

    (window as any).openEditBook = (id: number, title: string, isbn: string, year: string, author: number) => {
      setVal("eb-id", String(id));
      setVal("eb-title", title);
      setVal("eb-isbn", isbn);
      setVal("eb-year", year);
      setVal("eb-author", String(author));
      document.getElementById("modal-book")!.classList.add("open");
    };

    (window as any).updateBook = async () => {
      const params = `id=${val("eb-id")}&title=${val("eb-title")}&isbn=${val("eb-isbn")}&year=${val("eb-year")}`;
      const res = await fetch(`${BASE}/books?${params}`, { method: "PUT" });
      if (res.ok) { toast("Libro actualizado ✅"); closeModal("modal-book"); location.reload(); }
      else toast("Error al actualizar ❌", false);
    };

    (window as any).deleteBook = async (id: number) => {
      if (!confirm(`¿Eliminar libro ${id}?`)) return;
      const res = await fetch(`${BASE}/books?id=${id}`, { method: "DELETE" });
      if (res.ok) { document.getElementById(`book-${id}`)?.remove(); toast("Libro eliminado 🗑️"); }
      else toast("Error al eliminar ❌", false);
    };

    // ════════════════════════════════
    //  LOANS
    // ════════════════════════════════

    (window as any).createLoan = async () => {
      const params = new URLSearchParams({
        userId: val("l-user"),
        bookId: val("l-book"),
      });
      const res = await fetch(`${BASE}/loans`, { method: "POST", body: params });
      if (res.ok) { toast("Préstamo creado ✅"); location.reload(); }
      else toast("Error al crear préstamo ❌", false);
    };

    (window as any).deleteLoan = async (id: number) => {
      if (!confirm(`¿Eliminar préstamo ${id}?`)) return;
      const res = await fetch(`${BASE}/loans?id=${id}`, { method: "DELETE" });
      if (res.ok) { document.getElementById(`loan-${id}`)?.remove(); toast("Préstamo eliminado 🗑️"); }
      else toast("Error al eliminar ❌", false);
    };

    // Cerrar modales al hacer click fuera
    document.querySelectorAll(".modal-overlay").forEach(overlay => {
      overlay.addEventListener("click", (e) => {
        if (e.target === overlay) overlay.classList.remove("open");
      });
    });
  </script>

</body>
</html>